    {
      "parameters": {
        "jsCode": "const description = $input.item.json.description || \"\";\nconst match = description.match(/\\[OutlookID:\\s*(.*?)\\]/);\n\nif (match && match[1]) {\n  return {\n    json: {\n      ...$input.item.json,\n      extractedOutlookId: match[1] \n    }\n  };\n} else {\n  throw new Error(\"No Outlook twin ID found in description!\");\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
