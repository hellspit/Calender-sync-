        768
      ],
      "id": "4918fc75-3aae-4e74-a6ce-9f3294f4e461",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Get the description from the cancelled Google event\nconst description = $input.item.json.description || \"\";\n\n// Look for the exact OutlookID tag using a regular expression\nconst match = description.match(/\\[OutlookID:\\s*(.*?)\\]/);\n\n// If we find a match, extract the ID and pass it forward\nif (match && match[1]) {\n  return {\n    json: {\n      ...$input.item.json,\n      extractedOutlookId: match[1] \n    }\n  };\n} else {\n  // If there's no Outlook ID (meaning it wasn't synced by AgentCal), \n  // returning an empty array cleanly stops the workflow here.\n  return [];\n}"
      },
