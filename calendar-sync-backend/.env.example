# ─── Google OAuth (Web Application type) ─────────────────────────
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft OAuth ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=your-tenant-id

# ─── DynamoDB ────────────────────────────────────────────────────
DYNAMODB_USERS_TABLE=calendar-sync-users
DYNAMODB_MAPPINGS_TABLE=calendar-sync-mappings
DYNAMODB_IDEMPOTENCY_TABLE=calendar-sync-idempotency
AWS_REGION=us-east-1

# For local development with DynamoDB Local:
DYNAMODB_ENDPOINT=http://localhost:8000

# ─── Webhooks ────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com

# ─── API Authentication ─────────────────────────────────────────
# HMAC-SHA256 shared secret (must match mobile app)
API_SECRET_KEY=generate-a-strong-random-string-here

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
